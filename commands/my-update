#!/usr/bin/env bash

JSON_OUTPUT=false
STREAM_OUTPUT=false
COMMAND=""

for arg in "$@"; do
    case "$arg" in
        --json) JSON_OUTPUT=true ;;
        --stream) STREAM_OUTPUT=true ;;
        status|update)
            if [ -z "$COMMAND" ]; then
                COMMAND="$arg"
            fi
            ;;
    esac
done

if [ -z "$COMMAND" ]; then
    if [ "$JSON_OUTPUT" = true ]; then
        echo '{"text": "Argument error", "alt": "error"}'
    else
        echo "Использование: $0 {status|update} [--json] [--stream]"
    fi
    exit 1
fi

if [ "$STREAM_OUTPUT" = true ]; then
    if [ "$JSON_OUTPUT" = true ]; then
        echo '{"text": "Загрузка...", "alt": "is-loading"}'
    else
        echo "Выполнение: $COMMAND..."
    fi
fi

. "$HOME/Scripts/commands/.my-deps"

do_status() {
    if [ "$JSON_OUTPUT" = false ]; then
        echo "Проверка обновлений для системы"
    fi

    # 1. Pacman updates
    updates_list=$(checkupdates 2>/dev/null)
    updates_pacman=$(echo "$updates_list" | grep -v "^$" | wc -l)
    if [ "$JSON_OUTPUT" = false ]; then
        echo -e "\n1. Проверка обновлений пакетов через pacman:"
        if [ $updates_pacman -gt 0 ]; then
            echo "Найдено $updates_pacman пакетов для обновления через pacman."
            echo "$updates_list"
        else
            echo "Обновления для pacman не требуются."
        fi
    fi

    # 2. AUR updates
    yay_list=$(yay -Qua 2>/dev/null)
    updates_yay=$(echo "$yay_list" | grep -v "^$" | wc -l)
    if [ "$JSON_OUTPUT" = false ]; then
        echo -e "\n2. Проверка обновлений пакетов из AUR через yay:"
        if [ $updates_yay -gt 0 ]; then
            echo "Найдено $updates_yay пакетов из AUR для обновления через yay."
            echo "$yay_list"
        else
            echo "Обновления из AUR через yay не требуются."
        fi
    fi

    # 3. Flatpak updates
    flatpak_list=$(flatpak remote-ls --updates --columns=name,version 2>/dev/null)
    updates_flatpak=$(echo "$flatpak_list" | grep -v "^$" | wc -l)
    if [ "$JSON_OUTPUT" = false ]; then
        echo -e "\n3. Проверка обновлений Flatpak-приложений:"
        if [ $updates_flatpak -gt 0 ]; then
            echo "Найдено $updates_flatpak Flatpak‑приложений для обновления."
            echo "$flatpak_list"
        else
            echo "Обновления Flatpak‑приложений не требуются."
        fi
    fi

    # 4. Git updates
    if [ "$JSON_OUTPUT" = false ]; then
        echo -e "\n4. Проверка обновлений Git-репозиториев:"
    fi

    updates_git=0
    git_updates_list=""
    for repo in "${git_repos[@]}"; do
        cd "$repo" || continue

        if [ ! -d ".git" ]; then
            [ "$JSON_OUTPUT" = false ] && echo "Не является Git‑репозиторием: $repo"
            continue
        fi

        current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
        git fetch --quiet origin "$current_branch" 2>/dev/null
        behind_commits=$(git rev-list --count HEAD..origin/"$current_branch" 2>/dev/null)

        if [ "$behind_commits" -gt 0 ]; then
            updates_git=$((updates_git + 1))
            repo_name=$(basename "$repo")
            git_updates_list+="${repo_name} (${behind_commits} commits behind) "
        fi
    done

    total_updates=$((updates_pacman + updates_yay + updates_flatpak + updates_git))

    if [ "$JSON_OUTPUT" = true ]; then
        # Generate JSON
        text_report="Pacman: $updates_pacman, AUR: $updates_yay, Flatpak: $updates_flatpak, Git: $updates_git"
        alt_status="updated"
        if [ $total_updates -gt 0 ]; then alt_status="has-updates"; fi

        # Format lists for JSON (simple newline to space conversion or escape-ready)
        pacman_json=$(echo "$updates_list" | tr '\n' ',' | sed 's/,$//')
        yay_json=$(echo "$yay_list" | tr '\n' ',' | sed 's/,$//')
        flatpak_json=$(echo "$flatpak_list" | tr '\t' ' ' | tr '\n' ',' | sed 's/,$//')
        git_json=$(echo "$git_updates_list" | sed 's/ $//')

        cat <<STATUS_EOF
{"text": "$text_report","alt": "$alt_status","pacman": "$pacman_json","aur": "$yay_json","flatpak": "$flatpak_json","git": "$git_json","total": $total_updates}
STATUS_EOF
    else
        # Standard output summary
        echo -e "\n=============================================="
        if [ $total_updates -gt 0 ]; then
            echo "ВНИМАНИЕ: Всего доступно $total_updates обновлений. Рекомендуется выполнить обновление системы."
        else
            echo "Система полностью обновлена. Никаких обновлений не требуется."
        fi
    fi
}

do_update() {
    echo "Обновление pacman"
    sudo pacman -Syu --noconfirm

    echo "Обновление yay"
    sudo yay -Syu --noconfirm

    echo "Обновление flatpak"
    flatpak update --noninteractive

    echo "Обновление конфигураций"
    for repo in "${git_repos[@]}"; do
        cd "$repo" || continue

        if [ ! -d ".git" ]; then
            echo "Не является Git‑репозиторием: $repo"
            continue
        fi
        
        git fetch && git pull 
    done
    
    if [ "$JSON_OUTPUT" = true ]; then
        echo '{"text": "Обновление завершено","alt": "updated"}'
    else
        echo "Обновление завершено."
    fi
}

case "$COMMAND" in
    status)
        do_status
        ;;
    update)
        do_update
        ;;
esac
